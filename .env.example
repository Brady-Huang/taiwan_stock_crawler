# --- Database (MySQL) ---
MYSQL_USER=airflow_user
# Change this to your own password
MYSQL_ROOT_PASSWORD=enter_your_root_password
MYSQL_PASSWORD=enter_your_password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=taiwan_stock

# --- Cache (Redis) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Airflow ---
# AIRFLOW_FERNET_KEY is used to encrypt Airflow connection credentials.
# Must be a 32-byte base64-encoded string.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=enter_your_fernet_key

# AIRFLOW_WEBSERVER_SECRET_KEY is used to secure Airflow webserver sessions.
# Can be any random string.
AIRFLOW_WEBSERVER_SECRET_KEY=enter_your_secret_key

# --- API ---
API_PORT=8000