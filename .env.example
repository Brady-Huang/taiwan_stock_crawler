# --- Airflow ---
# AIRFLOW_FERNET_KEY is used to encrypt Airflow connection credentials.
# Must be a 32-byte base64-encoded string.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=46b9GVy8u_8L8S63p4p8S0S9S0S9S0S9S0S9S0S9S0S=

# AIRFLOW_WEBSERVER_SECRET_KEY is used to secure Airflow webserver sessions.
# Can be any random string.
AIRFLOW_WEBSERVER_SECRET_KEY=super-secret-key-for-webserver

# --- API ---
API_PORT=8000